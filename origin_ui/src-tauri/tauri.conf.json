{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Origin",
  "version": "0.1.0",
  "identifier": "com.origin.mesh",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Origin Network",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' asset: https://tauri.localhost http://tauri.localhost; connect-src 'self' ws://127.0.0.1:9944 http://127.0.0.1:8081;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
